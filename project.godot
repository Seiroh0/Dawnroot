; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Downroot"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.5")
config/icon="res://icon.svg"

[autoload]

GameRoot="*res://scripts/game_root.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=840
window/size/window_width_override=480
window/size/window_height_override=840
window/stretch/mode="viewport"

[input]

ui_cancel={
"deadzone": 0.5,
"events": [{
"device": 0,
"physical_keycode": 4194305,
"type": "InputEventKey"
}]
}
move_left={
"deadzone": 0.5,
"events": [{
"device": 0,
"physical_keycode": 65,
"type": "InputEventKey"
}, {
"device": 0,
"physical_keycode": 4194319,
"type": "InputEventKey"
}]
}
move_right={
"deadzone": 0.5,
"events": [{
"device": 0,
"physical_keycode": 68,
"type": "InputEventKey"
}, {
"device": 0,
"physical_keycode": 4194321,
"type": "InputEventKey"
}]
}
shoot={
"deadzone": 0.5,
"events": [{
"device": 0,
"physical_keycode": 32,
"type": "InputEventKey"
}, {
"device": 0,
"physical_keycode": 75,
"type": "InputEventKey"
}, {
"button_index": 1,
"device": 0,
"type": "InputEventMouseButton"
}]
}

[rendering]

textures/canvas_textures/default_texture_filter=0
